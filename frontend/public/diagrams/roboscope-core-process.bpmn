<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_RoboScopeCore"
                  targetNamespace="http://roboscope.eu/bpmn">
  <bpmn:process id="Process_RoboScopeCore" name="RoboScope Core Process" isExecutable="false">

    <!-- Start -->
    <bpmn:startEvent id="StartEvent_SelectRepo" name="Select&#10;Repository">
      <bpmn:outgoing>Flow_Start_Author</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Inclusive fork: author OR record (or both) -->
    <bpmn:inclusiveGateway id="Gateway_AuthorOrRecord" name="Author&#10;or Record?">
      <bpmn:incoming>Flow_Start_Author</bpmn:incoming>
      <bpmn:outgoing>Flow_Gw_Edit</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gw_Record</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <!-- Option A: edit in Explorer -->
    <bpmn:task id="Task_EditRobot" name="Edit .robot&#10;in Explorer">
      <bpmn:incoming>Flow_Gw_Edit</bpmn:incoming>
      <bpmn:outgoing>Flow_Edit_Merge</bpmn:outgoing>
    </bpmn:task>

    <!-- Option B: record with Recorder v2 -->
    <bpmn:task id="Task_RecordFlow" name="Record with&#10;Recorder v2">
      <bpmn:incoming>Flow_Gw_Record</bpmn:incoming>
      <bpmn:outgoing>Flow_Record_Merge</bpmn:outgoing>
    </bpmn:task>

    <bpmn:inclusiveGateway id="Gateway_AuthoringDone" name="Tests&#10;ready">
      <bpmn:incoming>Flow_Edit_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_Record_Merge</bpmn:incoming>
      <bpmn:outgoing>Flow_Merge_Trigger</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <!-- Trigger run -->
    <bpmn:task id="Task_TriggerRun" name="Trigger Run">
      <bpmn:incoming>Flow_Merge_Trigger</bpmn:incoming>
      <bpmn:outgoing>Flow_Trigger_Queue</bpmn:outgoing>
    </bpmn:task>

    <!-- Queue in executor -->
    <bpmn:task id="Task_Queue" name="Queue (single&#10;worker FIFO)">
      <bpmn:incoming>Flow_Trigger_Queue</bpmn:incoming>
      <bpmn:outgoing>Flow_Queue_ImageCheck</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateway: docker image fresh? -->
    <bpmn:exclusiveGateway id="Gateway_ImageFresh" name="Docker&#10;image fresh?">
      <bpmn:incoming>Flow_Queue_ImageCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_ImageStale</bpmn:outgoing>
      <bpmn:outgoing>Flow_ImageFresh</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_BuildImage" name="Build Docker&#10;Image">
      <bpmn:incoming>Flow_ImageStale</bpmn:incoming>
      <bpmn:outgoing>Flow_Build_Execute</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ReadyToExecute">
      <bpmn:incoming>Flow_ImageFresh</bpmn:incoming>
      <bpmn:incoming>Flow_Build_Execute</bpmn:incoming>
      <bpmn:outgoing>Flow_Ready_Execute</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Execute -->
    <bpmn:task id="Task_Execute" name="Execute Robot&#10;Framework">
      <bpmn:incoming>Flow_Ready_Execute</bpmn:incoming>
      <bpmn:outgoing>Flow_Execute_Parse</bpmn:outgoing>
    </bpmn:task>

    <!-- Parse output.xml -->
    <bpmn:task id="Task_Parse" name="Parse output.xml&#10;&#43; store report">
      <bpmn:incoming>Flow_Execute_Parse</bpmn:incoming>
      <bpmn:outgoing>Flow_Parse_Verdict</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateway: passed? -->
    <bpmn:exclusiveGateway id="Gateway_Verdict" name="Tests&#10;passed?">
      <bpmn:incoming>Flow_Parse_Verdict</bpmn:incoming>
      <bpmn:outgoing>Flow_Passed</bpmn:outgoing>
      <bpmn:outgoing>Flow_Failed</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AIAnalysis" name="AI failure&#10;analysis (opt.)">
      <bpmn:incoming>Flow_Failed</bpmn:incoming>
      <bpmn:outgoing>Flow_AI_EndFail</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Passed" name="Report&#10;OK">
      <bpmn:incoming>Flow_Passed</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Failed" name="Failure&#10;report">
      <bpmn:incoming>Flow_AI_EndFail</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Flows -->
    <bpmn:sequenceFlow id="Flow_Start_Author"     sourceRef="StartEvent_SelectRepo"  targetRef="Gateway_AuthorOrRecord" />
    <bpmn:sequenceFlow id="Flow_Gw_Edit"          sourceRef="Gateway_AuthorOrRecord" targetRef="Task_EditRobot" name="edit" />
    <bpmn:sequenceFlow id="Flow_Gw_Record"        sourceRef="Gateway_AuthorOrRecord" targetRef="Task_RecordFlow" name="record" />
    <bpmn:sequenceFlow id="Flow_Edit_Merge"       sourceRef="Task_EditRobot"         targetRef="Gateway_AuthoringDone" />
    <bpmn:sequenceFlow id="Flow_Record_Merge"     sourceRef="Task_RecordFlow"        targetRef="Gateway_AuthoringDone" />
    <bpmn:sequenceFlow id="Flow_Merge_Trigger"    sourceRef="Gateway_AuthoringDone"  targetRef="Task_TriggerRun" />
    <bpmn:sequenceFlow id="Flow_Trigger_Queue"    sourceRef="Task_TriggerRun"        targetRef="Task_Queue" />
    <bpmn:sequenceFlow id="Flow_Queue_ImageCheck" sourceRef="Task_Queue"             targetRef="Gateway_ImageFresh" />
    <bpmn:sequenceFlow id="Flow_ImageStale"       sourceRef="Gateway_ImageFresh"     targetRef="Task_BuildImage" name="no" />
    <bpmn:sequenceFlow id="Flow_ImageFresh"       sourceRef="Gateway_ImageFresh"     targetRef="Gateway_ReadyToExecute" name="yes" />
    <bpmn:sequenceFlow id="Flow_Build_Execute"    sourceRef="Task_BuildImage"        targetRef="Gateway_ReadyToExecute" />
    <bpmn:sequenceFlow id="Flow_Ready_Execute"    sourceRef="Gateway_ReadyToExecute" targetRef="Task_Execute" />
    <bpmn:sequenceFlow id="Flow_Execute_Parse"    sourceRef="Task_Execute"           targetRef="Task_Parse" />
    <bpmn:sequenceFlow id="Flow_Parse_Verdict"    sourceRef="Task_Parse"             targetRef="Gateway_Verdict" />
    <bpmn:sequenceFlow id="Flow_Passed"           sourceRef="Gateway_Verdict"        targetRef="EndEvent_Passed" name="pass" />
    <bpmn:sequenceFlow id="Flow_Failed"           sourceRef="Gateway_Verdict"        targetRef="Task_AIAnalysis" name="fail" />
    <bpmn:sequenceFlow id="Flow_AI_EndFail"       sourceRef="Task_AIAnalysis"        targetRef="EndEvent_Failed" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_RoboScopeCore">
    <bpmndi:BPMNPlane id="BPMNPlane_RoboScopeCore" bpmnElement="Process_RoboScopeCore">

      <!-- Top row: Start → AuthorOrRecord gw, with two parallel paths merging at AuthoringDone -->
      <bpmndi:BPMNShape id="StartEvent_SelectRepo_di" bpmnElement="StartEvent_SelectRepo">
        <dc:Bounds x="60" y="180" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="40" y="223" width="78" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AuthorOrRecord_di" bpmnElement="Gateway_AuthorOrRecord">
        <dc:Bounds x="155" y="173" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="138" y="230" width="85" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EditRobot_di" bpmnElement="Task_EditRobot">
        <dc:Bounds x="260" y="80" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordFlow_di" bpmnElement="Task_RecordFlow">
        <dc:Bounds x="260" y="250" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AuthoringDone_di" bpmnElement="Gateway_AuthoringDone">
        <dc:Bounds x="435" y="173" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="428" y="230" width="60" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TriggerRun_di" bpmnElement="Task_TriggerRun">
        <dc:Bounds x="540" y="160" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Queue_di" bpmnElement="Task_Queue">
        <dc:Bounds x="700" y="160" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ImageFresh_di" bpmnElement="Gateway_ImageFresh">
        <dc:Bounds x="870" y="170" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="853" y="227" width="85" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BuildImage_di" bpmnElement="Task_BuildImage">
        <dc:Bounds x="970" y="60" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ReadyToExecute_di" bpmnElement="Gateway_ReadyToExecute" isMarkerVisible="true">
        <dc:Bounds x="1145" y="170" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Execute_di" bpmnElement="Task_Execute">
        <dc:Bounds x="1240" y="160" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Parse_di" bpmnElement="Task_Parse">
        <dc:Bounds x="1400" y="160" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Verdict_di" bpmnElement="Gateway_Verdict" isMarkerVisible="true">
        <dc:Bounds x="1580" y="170" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1568" y="227" width="75" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Passed_di" bpmnElement="EndEvent_Passed">
        <bpmndi:BPMNLabel><dc:Bounds x="1659" y="120" width="45" height="30" /></bpmndi:BPMNLabel>
        <dc:Bounds x="1662" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AIAnalysis_di" bpmnElement="Task_AIAnalysis">
        <dc:Bounds x="1680" y="260" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Failed_di" bpmnElement="EndEvent_Failed">
        <bpmndi:BPMNLabel><dc:Bounds x="1843" y="338" width="60" height="30" /></bpmndi:BPMNLabel>
        <dc:Bounds x="1850" y="278" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="Flow_Start_Author_di" bpmnElement="Flow_Start_Author">
        <di:waypoint x="96"  y="198" />
        <di:waypoint x="155" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gw_Edit_di" bpmnElement="Flow_Gw_Edit">
        <di:waypoint x="180" y="173" />
        <di:waypoint x="180" y="115" />
        <di:waypoint x="260" y="115" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gw_Record_di" bpmnElement="Flow_Gw_Record">
        <di:waypoint x="180" y="223" />
        <di:waypoint x="180" y="285" />
        <di:waypoint x="260" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Edit_Merge_di" bpmnElement="Flow_Edit_Merge">
        <di:waypoint x="380" y="115" />
        <di:waypoint x="460" y="115" />
        <di:waypoint x="460" y="173" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Record_Merge_di" bpmnElement="Flow_Record_Merge">
        <di:waypoint x="380" y="285" />
        <di:waypoint x="460" y="285" />
        <di:waypoint x="460" y="223" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Merge_Trigger_di" bpmnElement="Flow_Merge_Trigger">
        <di:waypoint x="485" y="198" />
        <di:waypoint x="540" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Trigger_Queue_di" bpmnElement="Flow_Trigger_Queue">
        <di:waypoint x="660" y="195" />
        <di:waypoint x="700" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Queue_ImageCheck_di" bpmnElement="Flow_Queue_ImageCheck">
        <di:waypoint x="820" y="195" />
        <di:waypoint x="870" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ImageStale_di" bpmnElement="Flow_ImageStale">
        <di:waypoint x="895" y="170" />
        <di:waypoint x="895" y="95" />
        <di:waypoint x="970" y="95" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ImageFresh_di" bpmnElement="Flow_ImageFresh">
        <di:waypoint x="920" y="195" />
        <di:waypoint x="1145" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Build_Execute_di" bpmnElement="Flow_Build_Execute">
        <di:waypoint x="1090" y="95" />
        <di:waypoint x="1170" y="95" />
        <di:waypoint x="1170" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ready_Execute_di" bpmnElement="Flow_Ready_Execute">
        <di:waypoint x="1195" y="195" />
        <di:waypoint x="1240" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Execute_Parse_di" bpmnElement="Flow_Execute_Parse">
        <di:waypoint x="1360" y="195" />
        <di:waypoint x="1400" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Parse_Verdict_di" bpmnElement="Flow_Parse_Verdict">
        <di:waypoint x="1540" y="195" />
        <di:waypoint x="1580" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Passed_di" bpmnElement="Flow_Passed">
        <di:waypoint x="1605" y="170" />
        <di:waypoint x="1605" y="98" />
        <di:waypoint x="1662" y="98" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Failed_di" bpmnElement="Flow_Failed">
        <di:waypoint x="1605" y="220" />
        <di:waypoint x="1605" y="295" />
        <di:waypoint x="1680" y="295" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AI_EndFail_di" bpmnElement="Flow_AI_EndFail">
        <di:waypoint x="1800" y="295" />
        <di:waypoint x="1850" y="295" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
